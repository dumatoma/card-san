.contain {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  background: #fff;
  z-index: 999;
  overflow-y: scroll;
}
.contain .top1 {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 64rpx 40rpx 44rpx;
  justify-content: space-between;
  border-bottom: 2rpx solid #d2d2d7;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.contain .top2 {
  box-sizing: border-box;
  padding: 10rpx 40rpx 60rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  border-bottom: 2rpx solid #d2d2d7;
}
.contain .top3 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  background: #F5F5F7;
  box-sizing: border-box;
  padding: 80rpx 40rpx 44rpx;
  border-bottom: 2rpx solid #d2d2d7;
}
.contain .top4 .item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 60rpx 40rpx;
  border-bottom: 2rpx solid #d2d2d7;
}
.contain .top4 .item .itemLeft {
  display: flex;
  align-items: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.contain .top4 .item .itemLeft .selectContent {
  margin-right: 40rpx;
}
.contain .top4 .item .itemLeft .colorSq {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  opacity: 1;
  margin-left: 32rpx;
}
.contain .top4 .item .itemRight {
  width: 184rpx;
  height: 88rpx;
  background: #1A73E8;
  opacity: 1;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  border-radius: 18rpx;
  text-align: center;
  line-height: 88rpx;
}

