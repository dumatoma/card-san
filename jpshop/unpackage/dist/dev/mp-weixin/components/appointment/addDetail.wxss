.sexItem {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 43rpx 100rpx;
}
.colorItem {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 24rpx 100rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
}
.colorSqu {
  margin-right: 20rpx;
}
.currentColor {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 60rpx 40rpx;
}
.colorSqu {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
}
.insertContent {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding-left: 100rpx;
  border-bottom: 2rpx solid #d2d2d7;
  padding-bottom: 60rpx;
}
.selectItems {
  border-bottom: 2rpx solid #d2d2d7;
}
.contain {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  background: #fff;
  z-index: 999;
  overflow-y: scroll;
}
.contain .selectContent {
  margin-right: 32rpx;
}
.contain .detail {
  box-sizing: border-box;
  padding-top: 60rpx;
}
.contain .detail .managerName {
  box-sizing: border-box;
  padding: 36rpx 40rpx 40rpx;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  box-shadow: 0px 4px 12rpx 0rpx rgba(0, 0, 0, 0.16);
  z-index: 99;
}
.contain .detail .selectAll {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 60rpx 32rpx;
}
.contain .detail .sDitem {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 40rpx 32rpx;
  border-top: 2rpx solid #d2d2d7;
}
.contain .detail .sDitem .sDitemRight .sDtop {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 32rpx;
}
.contain .detail .sDitem .sDitemRight .sDbottom {
  display: flex;
}
.contain .detail .sDitem .sDitemRight .sDbottom .sDimage {
  width: 200rpx;
  height: 200rpx;
  margin-right: 32rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.contain .detail .sDitem .sDitemRight .sDbottom .sDimage image {
  width: 100%;
  height: 100%;
}
.contain .detail .sDitem .sDitemRight .sDbottom .sDinfo {
  display: flex;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.contain .detail .sDitem .sDitemRight .sDbottom .sDinfo .sDprice {
  color: #D93025;
  margin-right: 70rpx;
}
.contain .detail .sDtitle {
  width: 750rpx;
  height: 104rpx;
  background: #F5F5F7;
  opacity: 1;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #86868B;
  line-height: 104rpx;
  box-sizing: border-box;
  padding: 0 32rpx;
  border-top: 2rpx solid #d2d2d7;
}
.contain .tabs {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 26rpx;
}
.contain .tabs .tab {
  display: flex;
  align-items: center;
  background: #EAEAEA;
  border-radius: 16rpx;
}
.contain .tabs .tab .tab_item {
  box-sizing: border-box;
  padding: 16rpx 0;
  border-radius: 16rpx;
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.contain .tabs .tab .active {
  background: #fff;
  box-shadow: 0px 6rpx 16rpx 2rpx rgba(0, 0, 0, 0.16);
  color: #1A73E8 !important;
}

