.con {
  width: 750rpx;
  display: flex;
}
.con .time {
  box-sizing: border-box;
  padding: 0;
  position: relative;
  top: -40rpx;
}
.con .time .timeItem {
  height: 80rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  width: 158rpx;
  line-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: center;
}
.con .time .timeItem .timeName {
  flex: 1;
  text-align: center;
}
.con .time .timeItem .point {
  width: 20rpx;
  height: 2rpx;
  background-color: #EAEAEA;
}
.manager {
  width: 560rpx;
  overflow-x: scroll;
  display: flex;
  border-top: none;
  border-left: 2rpx solid #EAEAEA;
}
.manager .muItem {
  width: 80rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 0;
  position: relative;
  text-align: center;
  background: rgba(249, 249, 249, 0.94);
  border-right: 2rpx solid #eaeaea;
  border-top: 2rpx solid #eaeaea;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: rgba(217, 48, 37, 0.65);
  padding-top: 242rpx;
}
.manager .mItem {
  width: 80rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 0;
  position: relative;
}
.manager .mItem .dateItem {
  border: 2rpx solid #eaeaea;
  height: 80rpx;
  background: rgba(249, 249, 249, 0.94);
  text-align: center;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}
.manager .mItem .dateItem image {
  width: 48rpx;
  height: 48rpx;
}

