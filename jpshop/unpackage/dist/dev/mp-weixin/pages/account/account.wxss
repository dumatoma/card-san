page {
  background: #f5f5f5;
}
.num {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: #1a73e8;
  color: #fff;
  text-align: center;
  line-height: 52rpx;
  font-size: 32rpx;
}
.border_b {
  border-bottom: 2rpx solid #D2D2D7;
}
.settingItem {
  background: #fff;
  display: flex;
  height: 112rpx;
  justify-content: space-between;
  box-sizing: border-box;
  align-items: center;
  padding: 0 32rpx;
  border-top: 2rpx solid #D2D2D7;
}
.settingItem .itemLeft {
  display: flex;
  align-items: center;
}
.settingItem .itemLeft .itemIcon {
  width: 60rpx;
  margin-right: 20rpx;
}
.settingItem .itemLeft .itemIcon image {
  width: 100%;
}
.settingItem .itemLeft .itemName {
  font-family: 'Hiragino Sans';
  font-style: normal;
  font-weight: 400;
  font-size: 32rpx;
  color: #1D1D1F;
}
.settingItem .settingItem:last-child {
  border-bottom: 2rpx solid #D2D2D7;
}
.settingItem .warning {
  width: 52rpx;
  height: 52rpx;
}
.settingItem .warning image {
  width: 100%;
  height: 100%;
}
.settingItem .right {
  width: 22rpx;
  height: 44rpx;
}
.settingItem .right image {
  width: 100%;
  height: 100%;
}

