.mask {
  position: fixed;
  top: 0;
  left: 0;
}
.content {
  box-sizing: border-box;
  padding: 80rpx 46rpx 0;
}
.content .bt {
  width: 612rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-top: 318rpx;
}
.content .inp {
  margin-top: 100rpx;
}
.content .inp .inpName {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-bottom: 8rpx;
}
.content .details {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-top: 100rpx;
}
.content .nowMail {
  background: #F5F5F7;
  border-radius: 20rpx;
  box-sizing: border-box;
  padding: 32rpx;
}
.content .nowMail .now1 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-bottom: 32rpx;
}
.content .nowMail .now2 {
  font-size: 40rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}

