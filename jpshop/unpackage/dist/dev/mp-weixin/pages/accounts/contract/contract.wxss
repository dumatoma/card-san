.btips {
  background: rgba(26, 115, 232, 0.1);
  border-radius: 20rpx;
  opacity: 1;
  box-sizing: border-box;
  padding: 36rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  margin-top: 60rpx;
  margin-bottom: 120rpx;
}
.list_item {
  display: flex;
  box-sizing: border-box;
  padding: 40rpx 32rpx;
  align-items: center;
  font-size: 26rpx;
}
.list_item .item_list {
  border-bottom: 2rpx solid #D2D2D7;
}
.list_item .selectTime {
  width: 15%;
}
.list_item .selectPrice {
  width: 45%;
}
.list_item .selectDisccount {
  flex: 1;
  color: #D93025 !important;
}
.selectContent {
  width: 32rpx;
  height: 32rpx;
  box-sizing: border-box;
  padding: 6rpx;
  border: 2rpx solid #1A73E8;
  border-radius: 50%;
  margin-right: 10rpx;
}
.selectContent .selectInner {
  width: 100%;
  height: 100%;
  background: #1A73E8;
  border-radius: 50%;
}
.contain {
  background: #fff;
  box-sizing: border-box;
  padding: 100rpx 66rpx;
}
.contain .btitle {
  height: 80rpx;
  background: rgba(26, 115, 232, 0.1);
  text-align: center;
  line-height: 80rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.detail {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  line-height: 48rpx;
  padding-bottom: 40rpx;
}
.detail .detail_left {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.title {
  height: 112rpx;
  background: #F5F5F7;
  border-radius: 32rpx;
  text-align: center;
  line-height: 112rpx;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  left: 0;
  border-bottom: #d2d2d7;
}
.title .closeMask {
  width: 60rpx;
  height: 60rpx;
  position: absolute;
  left: 32rpx;
  top: 50%;
  -webkit-transform: translateY(-50%);
          transform: translateY(-50%);
}
.container {
  border-top: 2rpx solid #d2d2d7;
  box-sizing: border-box;
  padding: 0 32rpx;
}
.container .item {
  border-bottom: 2rpx solid #d2d2d7;
  box-sizing: border-box;
  padding: 82rpx 42rpx;
}
.container .item .changes {
  text-align: right;
  font-size: 28rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
}

