.title {
  display: flex;
  align-items: center;
  background: #F5F5F7;
  box-sizing: border-box;
  padding: 36rpx 46rpx;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.title .selectContents {
  margin-right: 20rpx;
}
.cTitle {
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  box-sizing: border-box;
  padding: 42rpx 0;
  text-align: center;
}
.tips {
  width: 658rpx;
  background: rgba(143, 168, 248, 0.2);
  border-radius: 20rpx;
  box-sizing: border-box;
  padding: 30rpx;
  font-size: 20rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  line-height: 36rpx;
  margin-top: 40rpx;
  margin-bottom: 58rpx;
}
.infoItem {
  display: flex;
  margin-bottom: 32rpx;
}
.infoItem .infoLeft {
  width: 154rpx;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-right: 20rpx;
}
.infoItem .infoRight {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.inner {
  box-sizing: border-box;
  padding: 60rpx 108rpx;
}
.inItem {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-bottom: 40rpx;
}
.select {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d2d2d7;
  border-radius: 8rpx;
  margin-right: 20rpx;
}
.select image {
  width: 100%;
  height: 100%;
}
.info {
  box-sizing: border-box;
  padding: 80rpx 52rpx 0;
  border-top: 2rpx solid #d2d2d7;
}
.info .in1 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.info .in2 {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}
.info .in3 {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-bottom: 20rpx;
}

