.tips {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-top: 24rpx;
}
.cb {
  margin-top: 160rpx;
  color: #aaa;
  border: 2rpx solid #aaa;
}
.pContent {
  background: #fff;
  width: 95vw;
  border-radius: 20rpx;
  height: 90vh;
  overflow-y: scroll;
}
.pContent .normalWord {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.pContent .titleWord {
  font-size: 24rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.pContent .pItem:nth-child(even) {
  background: rgba(143, 168, 248, 0.1);
}
.pContent .pItem {
  display: flex;
  align-items: center;
}
.pContent .pItem .pItemD {
  text-align: center;
}
.pContent .pItem .pItemD image {
  width: 35rpx;
  height: 35rpx;
}
.pContent .pItem .pItemD .explain {
  font-size: 20rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  text-align: center;
}
.pContent .pItem .p1 {
  width: 31%;
  box-sizing: border-box;
  padding: 30rpx 22rpx;
}
.pContent .pItem .p2 {
  width: 23%;
  box-sizing: border-box;
  padding: 30rpx 22rpx;
}
.pContent .pItem .p3 {
  width: 23%;
  box-sizing: border-box;
  padding: 30rpx 22rpx;
}
.pContent .pItem .p4 {
  width: 23%;
  box-sizing: border-box;
  padding: 30rpx 22rpx;
}
.pContent .close {
  width: 100%;
  display: flex;
  flex-direction: row-reverse;
  box-sizing: border-box;
  padding: 26rpx;
}
.pContent .close image {
  width: 60rpx;
  height: 60rpx;
}
.content {
  background: #F5F5F7;
  box-sizing: border-box;
  padding: 30rpx 32rpx;
}
.content .innerName {
  flex: 1;
  text-align: left;
  margin-left: 20rpx;
}
.content .packageItem {
  width: 100%;
  box-shadow: 0px 0px 20rpx 2rpx rgba(0, 0, 0, 0.16);
  background: #fff;
  margin-top: 60rpx;
}
.content .packageItem .innerItem {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 38rpx 32rpx;
  border-bottom: 2rpx solid #d2d2d7;
}
.content .packageItem .innerItem .innerLeft {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
  box-sizing: border-box;
  padding-right: 66rpx;
}
.content .packageItem .topcolor {
  width: 100%;
  height: 60rpx;
  text-align: center;
}
.content .packageItem .top1 {
  box-sizing: border-box;
  padding: 40rpx 80rpx 100rpx;
}
.content .packageItem .packageName {
  display: flex;
  justify-content: center;
  align-items: center;
}
.content .packageItem .packageName .realName {
  margin-left: 40rpx;
  font-size: 52rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.content .packageItem .packPrice {
  font-size: 40rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  text-align: center;
  margin-top: 40rpx;
}
.content .packageItem .introduce {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-top: 40rpx;
}
.content .packageItem .gitem {
  box-sizing: border-box;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 2rpx solid #d2d2d7;
}
.content .packageItem .gitem image {
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0 !important;
  margin-right: 10rpx;
}
.content .packageItem .citem {
  align-items: flex-start;
}
.content .review {
  height: 104rpx;
  background: #FFFFFF;
  opacity: 1;
  border: 2rpx solid #1A73E8;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  text-align: center;
  line-height: 104rpx;
  border-radius: 20rpx;
  margin-top: 60rpx;
}
.content .sq1 {
  background: #FFFFFF;
  box-shadow: 0px 0px 20px 2px rgba(0, 0, 0, 0.16);
  box-sizing: border-box;
  padding: 60rpx 32rpx;
}
.content .sq1 .using {
  height: 72rpx;
  background: #1A73E8;
  font-size: 32rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  text-align: center;
  line-height: 72rpx;
}
.content .sq1 .tips {
  background: rgba(143, 168, 248, 0.1);
  border-radius: 8rpx;
  box-sizing: border-box;
  padding: 32rpx;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  margin-top: 40rpx;
}
.content .sq1 .nameItem {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}
.content .sq1 .nameItem .name {
  flex: 1;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}

