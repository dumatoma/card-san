page {
  background-color: #f5f5f7;
  box-sizing: border-box;
  padding: 72rpx 40rpx;
}
.content {
  width: 100%;
  background-color: #fff;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 20rpx;
  box-sizing: border-box;
  padding: 78rpx 64rpx;
}
.content .but {
  width: 232rpx;
  height: 96rpx;
  background: #D2D2D7;
  text-align: center;
  line-height: 96rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  border-radius: 20rpx;
  margin: 0 auto;
}
.content .remark {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: center;
  margin-bottom: 100rpx;
}
.content .email {
  margin: 100rpx 0 58rpx;
  text-align: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.content .innerContent {
  box-sizing: border-box;
  padding: 40rpx 0;
}
.content .innerContent .innerItem {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.content .innerContent .innerItem .itemLeft {
  width: 140rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.content .innerContent .innerItem .itemRight {
  flex: 1;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.content .title {
  font-size: 36rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: center;
  margin-bottom: 58rpx;
}
.content .fu {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: center;
  padding-bottom: 80rpx;
  border-bottom: 2rpx solid #d2d2d7;
}

