<view><view class="content border_top"><view class="goodsInfo border_bottom"><view class="goodsImage"><image src="{{goods.image}}" mode="aspectFill"></image></view><view class="goodsInfos"><view class="goodsName">{{goods.goods_name}}</view><view class="goodsFormat"><view class="goodsPrice">{{goods.price}}</view><view class="goodsAmount">{{'×'+number}}</view></view><view class="goodsTotal">{{'合計金額: '+total+'円'}}<text>(税込)</text></view></view></view><view class="payMethods border_bottom"><view class="title">お支払い方法</view><view class="payName"><image src="../../../static/icons/cardLogo.png" mode></image><text>{{cardInfo[0].name}}</text></view><view class="payItem">{{'下４桁 '+cardInfo[0].cvv+''}}</view><view class="payItem">{{cardInfo[0].card_no}}</view><view class="payItem">{{'有効期限　'+cardInfo[0].expire_date+''}}</view></view><view class="addressContent"><view class="title">配送先住所</view><block wx:for="{{addressList}}" wx:for-item="item" wx:for-index="index"><view class="addressItem border_bottom"><view class="addressLeft"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" data-event-params="{{({index})}}" class="selectContent" bindtap="__e"><block wx:if="{{current!=index}}"><view class="unselect"></view></block><block wx:if="{{current==index}}"><view class="selected"><view class="fill"></view></view></block></view></view><view class="addressRight"><view class="addName">{{item.name}}</view><view class="addItem">{{'〒'+item.zip_code+''}}</view><view class="addItem">{{''+item.province+item.address1}}</view><view class="addItem">{{item.phone}}</view><view data-event-opts="{{[['tap',[['addNew',['$event']]]]]}}" class="addNew" bindtap="__e">別の住所に送る</view><block wx:if="{{current==index}}"><view data-event-opts="{{[['tap',[['deleItem',[index]]]]]}}" class="addNew" style="color:#D93025;" bindtap="__e">この住所を削除</view></block></view></view></block></view><view data-event-opts="{{[['tap',[['confirmOrder',['$event']]]]]}}" class="btn" bindtap="__e">ご注文確定</view><view style="height:200rpx;"></view></view></view>