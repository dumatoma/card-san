.goodsPrice {
  margin-right: 30rpx;
}
.btn {
  width: 580rpx;
  height: 100rpx;
  background: #ED8E20;
  border-radius: 50rpx;
  opacity: 1;
  text-align: center;
  line-height: 100rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  margin: 0 auto;
}
.content {
  box-sizing: border-box;
  padding: 0 40rpx;
}
.content .addressContent {
  box-sizing: border-box;
  padding: 44rpx 0;
}
.content .addressContent .addressItem {
  display: flex;
  padding-bottom: 44rpx;
  margin-bottom: 62rpx;
}
.content .addressContent .addressItem .addressLeft {
  margin-right: 20rpx;
}
.content .addressContent .addressItem .addItem {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 20rpx;
}
.content .addressContent .addressItem .addNew {
  margin-top: 60rpx;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
}
.content .addressContent .addressItem .shopName {
  font-size: 24rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.content .addressContent .addressItem .addName {
  margin-bottom: 28rpx;
}
.content .title {
  box-sizing: border-box;
  padding: 16rpx 0;
  margin-bottom: 28rpx;
  font-size: 28rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.content .payMethods {
  box-sizing: border-box;
  padding: 44rpx 0;
}
.content .payMethods .payName {
  display: flex;
  align-items: center;
}
.content .payMethods .payName image {
  width: 87rpx;
  height: 60rpx;
  margin-right: 20rpx;
}
.content .payMethods .payItem {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin: 16rpx 0;
}
.content .goodsInfo {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 40rpx 0;
}
.content .goodsInfo .goodsInfos .goodsName {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.content .goodsInfo .goodsInfos .goodsFormat {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin: 24rpx 0;
}
.content .goodsInfo .goodsInfos .goodsTotal {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.content .goodsInfo .goodsInfos .goodsTotal text {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.content .goodsInfo .goodsImage {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 28rpx;
}
.content .goodsInfo .goodsImage image {
  width: 100%;
  height: 100%;
}

