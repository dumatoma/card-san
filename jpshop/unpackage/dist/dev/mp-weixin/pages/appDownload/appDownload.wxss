.membership {
  width: 346rpx;
  height: 210rpx;
  margin: 60rpx auto 18rpx;
}
.membership image {
  width: 100%;
  height: 100%;
}
.memName {
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: center;
}
.tab {
  width: 100%;
  height: 210rpx;
  background: #fff;
  box-sizing: border-box;
  padding: 64rpx 30rpx 0;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
  border-top: 2rpx solid #D2D2D7;
}
.logo {
  width: 180rpx;
  height: 180rpx;
  margin: 58rpx auto 104rpx;
}
.logo image {
  width: 100%;
  height: 100%;
}
.qrcode {
  width: 448rpx;
  height: 448rpx;
  box-sizing: border-box;
  padding: 48rpx;
  margin: 0 auto;
}
.qrcode image {
  width: 100%;
  height: 100%;
}
.tabItem {
  text-align: center;
  line-height: 64rpx;
  flex: 1;
}
.tabContent {
  display: flex;
  align-items: center;
  background: #EAEAEA;
  width: 100%;
  border-radius: 16rpx;
  height: 72rpx;
}
.active {
  width: 344rpx;
  height: 64rpx;
  background: #FFFFFF;
  box-shadow: 0px 6rpx 16rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 16rpx;
  opacity: 1;
  border: 2rpx solid rgba(255, 255, 255, 0.04);
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
}
.btns {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 50rpx;
}
.btns .btn {
  width: 237rpx;
  height: 68rpx;
  margin: 0 20rpx;
}
.btns .btn image {
  width: 100%;
  height: 100%;
}

