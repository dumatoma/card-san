<view class="contain"><u-navbar vue-id="4f824280-1" title="予約" safeAreaInsetTop="{{true}}" bgColor="rgb(251,251,253)" placeholder="{{true}}" bind:__l="__l" vue-slots="{{['left','right']}}"><view class="u-nav-slot" slot="left"><image style="width:60rpx;height:60rpx;" src="../../static/icons/tclose.png" data-event-opts="{{[['tap',[['toIndex',['$event']]]]]}}" bindtap="__e"></image></view><view class="u-nav-slot" slot="right"><image style="width:60rpx;height:60rpx;" src="../../static/icons/fillSetting.png" data-event-opts="{{[['tap',[['showSetting',['$event']]]]]}}" bindtap="__e"></image></view></u-navbar><view class="top"><view class="topContent"><view data-event-opts="{{[['tap',[['toNotice',['$event']]]]]}}" class="content_item" bindtap="__e"><view class="item_left">予約通知</view><view class="item_right bk">{{totalNum}}</view></view><view class="content_item"><view class="item_left">今日の予約</view><view class="item_right">{{todayNum}}</view></view></view></view><view class="content"><view class="tabs"><view class="tab"><view data-event-opts="{{[['tap',[['changeTab',['day']]]]]}}" class="{{['tab_item',status=='day'?'active':'']}}" bindtap="__e">日</view><view data-event-opts="{{[['tap',[['changeTab',['week']]]]]}}" class="{{['tab_item',status=='week'?'active':'']}}" bindtap="__e">週</view></view></view><block wx:if="{{status=='week'}}"><view class="askForName"><view data-event-opts="{{[['tap',[['changeName',[0,0]]]]]}}" class="{{['name_item',current==0?'active':'']}}" bindtap="__e">指名なし</view><block wx:for="{{staff}}" wx:for-item="item" wx:for-index="index"><view data-event-opts="{{[['tap',[['changeName',['$0',index+1],[[['staff','',index,'id']]]]]]]}}" class="{{['name_item',current==index+1?'active':'']}}" bindtap="__e">{{item.name}}</view></block></view></block><view class="calendar"><lx-calendar bind:change="__e" vue-id="4f824280-2" data-event-opts="{{[['^change',[['change']]]]}}" bind:__l="__l"></lx-calendar></view><block wx:if="{{status=='day'}}"><view><progres vue-id="4f824280-3" manager="{{managers}}" times="{{times}}" data-event-opts="{{[['^addNew',[['addNewAppointment']]]]}}" bind:addNew="__e" bind:__l="__l"></progres></view></block><block wx:if="{{status=='week'}}"><view><week vue-id="4f824280-4" times="{{times}}" weekData="{{weekData}}" data-event-opts="{{[['^addNew',[['addNewAppointment']]]]}}" bind:addNew="__e" bind:__l="__l"></week></view></block><block wx:if="{{setting}}"><setting bind:close="__e" bind:goDetail="__e" vue-id="4f824280-5" data-event-opts="{{[['^close',[['closeSetting']]],['^goDetail',[['checkDetail']]]]}}" bind:__l="__l"></setting></block><block wx:if="{{showDetail}}"><setting-detail vue-id="4f824280-6" info="{{info}}" data-event-opts="{{[['^closeDetail',[['closeDetail']]]]}}" bind:closeDetail="__e" bind:__l="__l"></setting-detail></block><block wx:if="{{addNew}}"><new-appoint bind:cancel="__e" vue-id="4f824280-7" data-event-opts="{{[['^cancel',[['changeAdd']]]]}}" bind:__l="__l"></new-appoint></block></view></view>