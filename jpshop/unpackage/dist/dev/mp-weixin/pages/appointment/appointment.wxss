.con {
  width: 750rpx;
  display: flex;
}
.con .time {
  box-sizing: border-box;
  padding: 100rpx 0 0 30rpx;
  position: relative;
  top: -40rpx;
}
.con .time .timeItem {
  height: 80rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  width: 130rpx;
  line-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: center;
}
.con .time .timeItem .timeName {
  flex: 1;
  text-align: center;
}
.con .time .timeItem .point {
  width: 20rpx;
  height: 2rpx;
  background-color: #EAEAEA;
}
.manager {
  width: 560rpx;
  overflow-x: scroll;
  display: flex;
  border-top: none;
  border-left: 2rpx solid #EAEAEA;
}
.manager .mItem {
  width: 140rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 0;
  position: relative;
}
.manager .mItem .mContent {
  width: 100%;
  border-top: 2rpx solid #eaeaee;
  position: relative;
}
.manager .mItem .mContent .dateItem {
  width: 100%;
  height: 80rpx;
  box-sizing: border-box;
  border: 2rpx solid #EAEAEA;
  border-left: none;
  border-top: none;
  font-size: 24rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
}
.manager .mItem .mContent .dateItem .itemName {
  box-sizing: border-box;
  position: relative;
  padding: 16rpx 8rpx 0;
}
.manager .mItem .mContent .dateItem .itemName .bd {
  width: 100%;
  height: 8rpx;
  border-radius: 8rpx;
  position: absolute;
  top: 0;
  left: 0;
}
.manager .mItem .mContent .dateItem .itemEvent {
  box-sizing: border-box;
  padding: 0 8rpx;
}
.manager .mItem .mTop {
  height: 100rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  left: 0;
}
.manager .mItem .mTop .pe {
  width: 100%;
  text-align: center;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #86868B;
  margin-bottom: 6rpx;
}
.manager .mItem .mTop .pecolor {
  width: 128rpx;
  height: 8rpx;
  border-radius: 8rpx;
  margin: 0 auto;
  position: absolute;
  bottom: 16rpx;
  left: 6rpx;
}

