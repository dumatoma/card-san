.askForName {
  display: flex;
  align-items: center;
  width: 100%;
  overflow-x: scroll;
  box-sizing: border-box;
  padding: 40rpx 0 40rpx 40rpx;
  background: rgba(249, 249, 249, 0.94);
}
.askForName .name_item {
  padding: 8rpx 16rpx;
  border: 2rpx solid #AAAAAA;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
  flex-shrink: 0;
  border-radius: 8rpx;
  margin-right: 20rpx;
}
.askForName .active {
  background: rgba(26, 115, 232, 0.1);
  color: #007AFF;
  border: 2rpx solid #1A73E8;
}
.top {
  box-sizing: border-box;
  padding: 40rpx 32rpx;
  background: #F5F5F7;
}
.top .topContent {
  background-color: #fff;
  border: 2rpx solid #d2d2d7;
  border-radius: 20rpx;
}
.top .topContent .content_item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
  padding: 40rpx 34rpx;
}
.top .topContent .content_item .bk {
  background-color: #1A73E8;
  color: #fff !important;
}
.top .topContent .content_item .item_right {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  color: #1D1D1F;
  text-align: center;
  line-height: 60rpx;
}
.top .topContent .content_item:first-child {
  border-bottom: 2rpx solid #d2d2d7;
}
.content {
  background: #fff;
}
.content .tabs {
  width: 100%;
  box-sizing: border-box;
  padding: 40rpx 26rpx;
}
.content .tabs .tab {
  display: flex;
  align-items: center;
  background: #EAEAEA;
  border-radius: 16rpx;
}
.content .tabs .tab .tab_item {
  box-sizing: border-box;
  padding: 20rpx 0;
  border-radius: 16rpx;
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.content .tabs .tab .active {
  background: #fff;
  box-shadow: 0px 6rpx 16rpx 2rpx rgba(0, 0, 0, 0.16);
  color: #1A73E8 !important;
}

