.co {
  box-sizing: border-box;
  padding: 0 40rpx;
}
.co .tips {
  box-sizing: border-box;
  padding: 28rpx;
  background: #F5F5F7;
  color: #1D1D1F;
  border-radius: 20rpx;
  font-size: 28rpx;
  margin-top: 80rpx;
}
.co .tips .connect {
  color: #1A73E8;
  margin-top: 20rpx;
}
.co .content {
  border-bottom: 2rpx solid #d2d2d7;
  box-sizing: border-box;
  padding: 32rpx 0 58rpx 0;
}
.co .content .detail {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.co .content .tiem {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  margin-top: 20rpx;
}
.co .content .tiem .price {
  color: rgba(217, 48, 37, 0.65);
}
.co .content .tiem .time {
  color: #1D1D1F;
}
.co .content .coTime {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
  text-align: right;
}
.co .content .item {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.co .content .item .item_left {
  width: 160rpx;
}
.co .content .item .item_right {
  display: flex;
  align-items: center;
}
.co .content .item .item_right .squ {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

