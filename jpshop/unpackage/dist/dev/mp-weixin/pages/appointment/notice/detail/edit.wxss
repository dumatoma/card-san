.peoItem {
  background: #fff;
  border-bottom: 2rpx solid #d2d2d7;
  display: flex;
  box-sizing: border-box;
  padding: 60rpx 30rpx;
}
.peoItem .peoSqu {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-left: 36rpx;
  margin-right: 20rpx;
}
.cConfirm {
  font-size: 40rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  text-align: center;
  box-sizing: border-box;
  padding: 72rpx 0 186rpx 0;
}
.selectContent {
  margin-right: 32rpx;
}
.detail {
  box-sizing: border-box;
}
.detail .managerName {
  box-sizing: border-box;
  padding: 36rpx 40rpx 40rpx;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  box-shadow: 0px 4px 12rpx 0rpx rgba(0, 0, 0, 0.16);
  z-index: 99;
}
.detail .selectAll {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 60rpx 32rpx;
}
.detail .allname {
  color: #D93025 !important;
}
.detail .sDitem {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 40rpx 32rpx;
  border-top: 2rpx solid #d2d2d7;
}
.detail .sDitem .sDitemRight .sDtop {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 32rpx;
}
.detail .sDitem .sDitemRight .sDbottom {
  display: flex;
}
.detail .sDitem .sDitemRight .sDbottom .sDimage {
  width: 200rpx;
  height: 200rpx;
  margin-right: 32rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.detail .sDitem .sDitemRight .sDbottom .sDimage image {
  width: 100%;
  height: 100%;
}
.detail .sDitem .sDitemRight .sDbottom .sDinfo {
  display: flex;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.detail .sDitem .sDitemRight .sDbottom .sDinfo .sDprice {
  color: #D93025;
  margin-right: 70rpx;
}
.detail .sDtitle {
  width: 750rpx;
  height: 104rpx;
  background: #F5F5F7;
  opacity: 1;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #86868B;
  line-height: 104rpx;
  box-sizing: border-box;
  padding: 0 32rpx;
  border-top: 2rpx solid #d2d2d7;
}
.title {
  width: 100%;
  height: 112rpx;
  background: #F5F5F7;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  text-align: center;
  line-height: 112rpx;
  display: flex;
  justify-content: center;
  position: relative;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  left: 0;
  z-index: 999;
  border-bottom: 2rpx solid #d2d2d7;
}
.title image {
  width: 60rpx;
  height: 60rpx;
  position: absolute;
  top: 26rpx;
  left: 32rpx;
}
.titleName {
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.citem {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 20rpx 0;
}
.citem .citemLeft {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.citem .citemRight .cperson {
  display: flex;
  align-items: center;
}
.citem .citemRight .cperson .pcolor {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.citem .citemRight .cperson .pname {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #6E6E73;
  margin-left: 20rpx;
  margin-right: 38rpx;
}
.citem .dateDetail {
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #F5F5F7;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.pickers {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  justify-content: space-between;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.sexItem {
  text-align: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  box-sizing: border-box;
  padding: 30rpx 0;
}
.contain {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  background: #f5f5f7;
  z-index: 999;
  overflow-y: scroll;
  box-sizing: border-box;
  padding: 32rpx;
}
.contain .ct {
  width: 100%;
  background: #fff;
  box-sizing: border-box;
  padding: 60rpx 32rpx;
  border-radius: 20rpx;
  border: 2rpx solid #D2D2D7;
  margin-bottom: 40rpx;
}
.contain .ct .ctItem {
  display: flex;
  margin-top: 56rpx;
  align-items: center;
}
.contain .ct .ctItem .itemName {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.contain .ct .ctItem .itemDetail {
  flex: 1;
}
.contain .ct .ctItem .itemDetail .picker {
  width: 420rpx;
  height: 84rpx;
  background: #F5F5F7;
  border-radius: 20rpx;
  opacity: 1;
  border: 2rpx solid #AAAAAA;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 0 20rpx;
}

