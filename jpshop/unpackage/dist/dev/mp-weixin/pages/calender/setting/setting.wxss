.pContent {
  width: 100vw;
  height: 90vh;
  background: #fff;
  overflow-y: scroll;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
}
.pContent .Cdate {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 10rpx 50rpx;
}
.pContent .Cdate .CdateItem:last-child {
  margin-left: 156rpx;
}
.pContent .Cdate .CdateItem {
  display: flex;
  align-items: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
}
.pContent .Cdate .CdateItem .selectContent {
  margin-right: 28rpx;
}
.pContent .dateInfo {
  font-size: 48rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  display: flex;
  box-sizing: border-box;
  padding: 92rpx 40rpx;
}
.pContent .dateInfo .todate {
  margin-right: 60rpx;
}
.pContent .title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 32rpx 26rpx;
  background: #FBFBFD;
  border-bottom: 2rpx solid #d2d2d7;
}
.pContent .title .titleName {
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.warnning {
  display: flex;
  align-items: center;
  margin: 42rpx auto 158rpx;
  text-align: center;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #D93025;
  text-align: center;
  justify-content: center;
}
.btn {
  width: 480rpx;
  height: 96rpx;
  border-radius: 20rpx;
}
.selectContent {
  margin-right: 20rpx;
}
.tips {
  box-sizing: border-box;
  padding-top: 60rpx;
}
.tips .tipContent {
  width: 656rpx;
  height: 110rpx;
  background: rgba(29, 29, 31, 0.1);
  border-radius: 20rpx;
  opacity: 1;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  box-sizing: border-box;
  padding: 20rpx;
  margin: 0 auto 92rpx;
}
.timeContent {
  flex: 1;
}
.timeContent .timItems {
  display: flex;
  align-items: center;
}
.timeContent .timItems:nth-child(2) {
  margin-top: 40rpx;
}
.timePicker .pickerTitle {
  display: flex;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-top: 96rpx;
  border-bottom: 2rpx solid #d2d2d7;
  padding-bottom: 12rpx;
}
.timePicker .pickerTitle .titleitem {
  flex: 1;
  text-align: center;
}
.timePicker .pickerContent .pickerItem {
  display: flex;
  align-items: center;
  flex: 1;
  text-align: center;
  box-sizing: border-box;
  padding: 40rpx 0;
  border-bottom: 2rpx solid #d2d2d7;
}
.timePicker .pickerContent .pickerItem .pItem {
  flex: 1;
}
.timePicker .pickerContent .pickerItem .pItem:last-child {
  position: relative;
  left: 60rpx;
}

