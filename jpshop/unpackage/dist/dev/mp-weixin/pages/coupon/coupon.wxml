<view><u-navbar vue-id="62b22a80-1" leftText="返回" border="{{true}}" placeholder="{{true}}" title="クーポン一覧" safeAreaInsetTop="{{true}}" bind:__l="__l" vue-slots="{{['default','left','right']}}"><view class="u-nav-slot" slot="left"><image style="width:60rpx;height:60rpx;" src="../../static/icons/tclose.png" mode data-event-opts="{{[['tap',[['toBack',['$event']]]]]}}" bindtap="__e"></image></view><view class="u-nav-slot" slot="right"><image style="width:60rpx;height:60rpx;" src="../../static/icons/addB.png" mode data-event-opts="{{[['tap',[['toEdit',['$event']]]]]}}" bindtap="__e"></image></view>[]</u-navbar><view class="title"><view class="titleLeft">配信履歴</view><view class="titleRight"><view>メッセージ数/月</view><view>2000/5000</view></view></view><view class="content"><block wx:for="{{array}}" wx:for-item="item" wx:for-index="index"><view class="item"><view data-event-opts="{{[['tap',[['showModual',[index]]]]]}}" class="{{['itemLeft',current!=index?'border':'']}}" bindtap="__e"><block wx:if="{{current==index}}"><image src="../../static/icons/select.png" mode></image></block></view><view class="itemRight"><view class="iImage"><u-swiper vue-id="{{'62b22a80-2-'+index}}" list="{{item.images}}" height="200" autoplay="{{false}}" bind:__l="__l"></u-swiper></view><view class="iInfo"><view class="info1"><view class="i1Left"></view><view class="i1Right"><block wx:if="{{item.is_send==0}}"><view class="op1">予約中</view></block><block wx:if="{{item.is_send==1&&item.indate==1}}"><view class="op3">有効</view></block><block wx:if="{{item.is_send==1&&item.indate==0}}"><view class="op4">期限切</view></block><block wx:if="{{item.is_send==1}}"><view class="op2">配信済</view></block></view></view><view class="info2">{{item.title}}</view><view class="info3">NO:<text>{{item.number}}</text></view><view class="info4">{{item.indate_start_time+' ~ '+item.indate_end_time}}</view><view class="info5"><view class="infoItem">{{'配信数:'+item.send_count}}</view><view class="infoItem">{{'バーコード:'+(item.is_bar_code==1?'あり':'なし')+''}}</view></view><view class="info5"><view class="infoItem">{{'利用者数:'+item.use_count}}</view><view class="infoItem">{{'回数制限:'+item.count}}</view></view></view></view></view></block></view><u-action-sheet vue-id="62b22a80-3" round="{{20}}" actions="{{list}}" show="{{show}}" data-event-opts="{{[['^select',[['choose']]],['^close',[['close']]]]}}" bind:select="__e" bind:close="__e" bind:__l="__l"></u-action-sheet></view>