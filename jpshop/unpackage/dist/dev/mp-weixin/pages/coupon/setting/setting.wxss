.container {
  border-top: 2rpx solid #D2D2D7;
  box-sizing: border-box;
  padding-top: 24rpx;
}
.container .cons {
  text-align: center;
}
.container .can {
  width: 100%;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #aaa;
  overflow: hidden;
  margin: 34rpx 0 60rpx;
}
.container .can .canLeft {
  background: #EAEAEA;
  text-align: center;
  border-right: 2rpx solid #aaa;
  height: 100%;
  line-height: 80rpx;
  width: 80rpx;
  box-sizing: border-box;
  padding-left: 8rpx;
}
.container .fu {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.container .appointSet {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 43rpx;
  border-bottom: 2rpx solid #d2d2d7;
  padding-bottom: 30rpx;
}
.container .blank {
  width: 100%;
  height: 50rpx;
}
.container .btn {
  width: 478rpx;
  height: 96rpx;
  background: rgba(29, 29, 31, 0.1);
  border-radius: 20rpx;
  opacity: 1;
  border: 2rpx solid #707070;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-top: 144rpx;
}
.container .content {
  border-left: 2rpx solid #D2D2D7;
  border-right: 2rpx solid #D2D2D7;
  border-top: 2rpx solid #D2D2D7;
  margin: 32rpx 0 0;
}
.container .contentItem {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 32rpx;
  border-bottom: 2rpx solid #D2D2D7;
}
.container .contentItem .tabLeft .tabTop {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 20rpx;
}
.container .contentItem .tabLeft .tabBot {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
}
.container .contentItem .tabRight image {
  height: 46rpx;
  width: 23rpx;
}
.container .item {
  display: flex;
  align-items: center;
  margin-top: 60rpx;
}
.container .item .itemLeft {
  margin-right: 28rpx;
}
.container .item .unselect {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  opacity: 1;
  box-sizing: border-box;
  border: 2rpx solid #707070;
  border-radius: 50%;
}
.container .item .selected {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border: 2rpx solid #1A73E8;
  border-radius: 50%;
  box-sizing: border-box;
  padding: 6rpx;
}
.container .item .selected .fill {
  width: 100%;
  height: 100%;
  background: #1A73E8;
  border-radius: 50%;
}
.container .mem1 {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  text-align: right;
  margin-bottom: 14rpx;
}
.container .mem2 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  text-align: right;
}
.container .mem2 text {
  color: #1D1D1F;
}
.container .title {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-top: 40rpx;
  border-bottom: 2rpx solid #d2d2d7;
  padding-bottom: 22rpx;
}

