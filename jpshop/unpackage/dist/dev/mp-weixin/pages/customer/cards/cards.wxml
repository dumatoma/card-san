<view class="contain"><view class="topUser"><text>{{query.name}}</text>のご利用中のカード</view><view class="cards"><block wx:for="{{array}}" wx:for-item="item" wx:for-index="index"><view data-event-opts="{{[['tap',[['change',[index]]]]]}}" class="cardItem" style="{{(item.checked?'background:rgba(143,168,248,0.1)':'')}}" bindtap="__e"><view class="itemLeft"><block wx:if="{{!item.checked}}"><view class="unselect"></view></block><block wx:if="{{item.checked}}"><view class="selected"><view class="fill"></view></view></block></view><view class="itemRight"><view class="right1">{{item.name}}</view><view class="right2">{{'スタンプ数 : '+item.count+'個'}}</view><block wx:if="{{item.valid_type==2}}"><view class="right3">{{'有効期限：'+item.expire_time+''}}</view></block><block wx:if="{{item.valid_day==1}}"><view class="right3">{{'有効期限：'+item.valid_day+' 后到期'}}</view></block><block wx:if="{{item.valid_day==0}}"><view class="right3">有効期限：无限期</view></block><view class="right4"><text>カード背景色</text><view class="sq" style="{{'background:'+item.background_color}}"></view></view><view class="right5"><image src="{{item.image}}" mode></image></view></view></view></block></view></view>