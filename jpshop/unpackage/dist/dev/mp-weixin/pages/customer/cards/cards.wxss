.topUser {
  box-sizing: border-box;
  padding: 80rpx 40rpx 40rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  box-shadow: 0px 0px 10rpx 2rpx rgba(0, 0, 0, 0.16);
  border-top: 2rpx solid #d2d2d7;
}
.topUser text {
  font-weight: bold;
}
.right1 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  color: #1D1D1F;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.right2 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 20rpx;
}
.right3 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 20rpx;
}
.right4 {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 40rpx;
}
.right4 .sq {
  width: 200rpx;
  height: 40rpx;
  background: #53B1AF;
  box-shadow: 0px 0px 6rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 8rpx;
  margin-left: 20rpx;
}
.right5 {
  width: 550rpx;
  height: 328rpx;
  background: #FFFFFF;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
}
.right5 image {
  width: 100%;
  height: 100%;
}
.cardItem {
  display: flex;
  box-sizing: border-box;
  padding: 40rpx 40rpx 0;
  padding-right: 0;
}
.itemLeft {
  margin-right: 24rpx;
  flex-shrink: 0;
}
.itemRight {
  flex: 1;
  border-bottom: 2rpx solid #D2D2D7;
  padding-bottom: 80rpx;
}
.unselect {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  opacity: 1;
  box-sizing: border-box;
  border: 2rpx solid #707070;
  border-radius: 50%;
}
.selected {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border: 2rpx solid #1A73E8;
  border-radius: 50%;
  box-sizing: border-box;
  padding: 6rpx;
}
.selected .fill {
  width: 100%;
  height: 100%;
  background: #1A73E8;
  border-radius: 50%;
}

