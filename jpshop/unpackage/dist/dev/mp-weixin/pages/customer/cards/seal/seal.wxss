.tc {
  color: #1A73E8;
}
.btn {
  width: 328rpx;
  height: 100rpx;
  background: #1A73E8;
  border-radius: 20rpx;
  text-align: center;
  font-size: 40rpx;
  color: #fff;
  margin-top: 60rpx;
}
.coiunt {
  font-size: 80rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
  margin: 0 120rpx;
}
.choosecount {
  display: flex;
  align-items: center;
  justify-content: center;
}
.reduce, .plus {
  width: 80rpx;
  height: 80rpx;
}
.reduce image, .plus image {
  width: 100%;
  height: 100%;
}
.blank {
  width: 100%;
  height: 40rpx;
  background: #FBFBFD;
  z-index: -1;
}
.popTitle {
  padding: 40rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.userInfo {
  border-top: 2rpx solid #d2d2d7;
  border-bottom: 2rpx solid #d2d2d7;
  box-sizing: border-box;
  padding: 32rpx 40rpx 12rpx;
}
.special {
  background: #FFFFFF;
  box-shadow: 0px 0px 10rpx 2rpx rgba(29, 29, 31, 0.16);
  box-sizing: border-box;
  padding: 40rpx 0;
}
.special .remark {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  box-sizing: border-box;
  padding: 58rpx 40rpx 40rpx;
}
.special .specialTitle {
  width: 144rpx;
  height: 60rpx;
  background: #D93025;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-family: Hiragino Sans-W4, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  line-height: 60rpx;
  text-align: center;
  position: relative;
  left: 46rpx;
  margin-bottom: 20rpx;
}
.appoint {
  box-sizing: border-box;
  padding: 32rpx 46rpx;
  box-shadow: 0px 0px 10rpx 2rpx rgba(0, 0, 0, 0.16);
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}
.appoint .appointTitle {
  width: 144rpx;
  height: 60rpx;
  background: #1A73E8;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  text-align: center;
  line-height: 60rpx;
}
.appoint .appointItem {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
}
.appoint .appointItem .aItem {
  display: flex;
}
.appoint .appointItem .aItem .aItemImage {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}
.appoint .appointItem .aItem .aItemImage image {
  width: 100%;
  height: 100%;
}
.cardInfo {
  box-sizing: border-box;
  padding: 40rpx 18rpx 0;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
  background: #fff;
  z-index: 99;
}
.cardInfo .cardTitle {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: center;
  width: 100%;
}
.cardInfo .cardInfos {
  margin-top: 40rpx;
  box-sizing: border-box;
  padding: 0 32rpx 40rpx;
  background: #fff;
}
.cardInfo .cardInfos .ciItem {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.cardInfo .cardInfos .ciItem .ciLeft {
  width: 144rpx;
  height: 60rpx;
  background: #F5F5F7;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  text-align: center;
  line-height: 60rpx;
  margin-right: 28rpx;
}
.cardInfo .cardInfos .ciItem .ciRight {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.cardInfo .cardY {
  width: 100%;
  height: 398rpx;
  background: #53B1AF;
  box-shadow: 0px 0px 10rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 12rpx;
  margin-top: 20rpx;
  box-sizing: border-box;
  padding: 36rpx;
}
.cardInfo .cardY .cardInner {
  width: 100%;
  height: 100%;
  background-color: #fff;
  display: flex;
  flex-wrap: wrap;
}
.cardInfo .cardY .cardInner .seal {
  width: 20%;
  height: 50%;
  box-sizing: border-box;
  border-right: 2rpx solid #eaeaea;
  border-bottom: 2rpx solid #eaeaea;
  text-align: center;
  position: relative;
}
.cardInfo .cardY .cardInner .seal .sealed {
  position: absolute;
  width: 100%;
  height: 100%;
  left: 0;
  top: 32rpx;
}
.cardInfo .cardY .cardInner .seal .sealed image {
  width: 80rpx;
  height: 80rpx;
}
.cardInfo .cardY .cardInner .seal .sealed .sealTime {
  font-size: 20rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  text-align: center;
}
.cardInfo .cardY .cardInner .seal text {
  font-size: 48rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #EAEAEA;
  line-height: 170rpx;
}
.infoItem {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  margin-bottom: 20rpx;
}
.infoItem .itemname {
  color: #707070;
  margin-right: 70rpx;
  width: 128rpx;
}
.infoItem .itemValue {
  color: #1D1D1F;
}

