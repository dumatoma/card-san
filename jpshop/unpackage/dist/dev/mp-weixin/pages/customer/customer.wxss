.u-page {
  padding: 0;
}
.listContent {
  box-sizing: border-box;
  padding: 5rpx 32rpx;
}
.u-demo-block__title {
  padding: 10rpx 0 2rpx 15rpx;
}
.swipe-action__content {
  padding: 25rpx 0;
}
.swipe-action__content__text {
  font-size: 15px;
  color: #303133;
  padding-left: 30rpx;
}
.userName {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.tel {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.userId {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.itemLeft {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
}
.itemLeft image {
  width: 100%;
  height: 100%;
}
.itemContent {
  display: flex;
  align-items: center;
}
.tc {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
}
.searchContent {
  width: 100%;
  height: 240rpx;
  box-shadow: 0px 0px 0px 2rpx rgba(0, 0, 0, 0.3);
  border-top: 2rpx solid #FBFBFD;
  box-sizing: border-box;
  padding: 50rpx 32rpx 0;
}
.search {
  background: rgba(118, 118, 128, 0.12);
  border-radius: 12rpx;
  overflow: hidden;
}
.order {
  display: flex;
  align-items: center;
  margin-top: 50rpx;
}
.order image {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

