page {
  background-color: #F5F5F5;
}
.arrows {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}
.arrows image {
  height: 60rpx;
  width: 50rpx;
  margin: 0 40rpx;
}
.custom-style {
  margin-top: 48rpx;
  margin-bottom: 52rpx;
  background: rgba(29, 29, 31, 0.1) !important;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.bolderWord {
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: bold;
}
.packageContent {
  width: 686rpx;
  background: #fff;
}
.packageContent .warningTitle {
  width: 100%;
  padding: 40rpx 0;
  background: rgba(217, 48, 37, 0.1);
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #D93025;
  text-align: center;
}
.packageContent .alertTitle {
  width: 100%;
  height: 96rpx;
  background: rgba(143, 168, 248, 0.1);
  text-align: center;
  line-height: 96rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.packageContent .packageDetail {
  box-sizing: border-box;
  padding: 52rpx;
}
.packageContent .packageDetail .pd1 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  box-sizing: border-box;
  padding: 28rpx 0;
  margin-bottom: 52rpx;
}
.packageContent .packageDetail .pd2 {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 52rpx;
}
.apply_btn {
  width: 252rpx;
  height: 60rpx;
  background: #1A73E8;
  border-radius: 32rpx;
  text-align: center;
  line-height: 60rpx;
  color: #fff;
  font-size: 24rpx;
}
.tips {
  width: 654rpx;
  height: 100rpx;
  background: #FFFFFF;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 12rpx;
  opacity: 1;
  margin: 0 auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 0 20rpx;
}
.tips .tips_left {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1d1d1f;
}
.contain {
  box-sizing: border-box;
}
.cons {
  width: 100vw;
  height: 90vh;
  border-top-left-radius: 15rpx;
  border-top-right-radius: 15rpx;
  background: #fff;
  overflow-y: scroll;
  position: relative;
}
.cons .btn1 {
  width: 480rpx;
  height: 96rpx;
  background: rgba(217, 48, 37, 0.6);
  border-radius: 20rpx;
  opacity: 1;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  margin-top: 120rpx;
}
.cons .btn2 {
  width: 480rpx;
  height: 96rpx;
  background: rgba(29, 29, 31, 0.1);
  border-radius: 20rpx;
  opacity: 1;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-top: 80rpx;
}
.cons .details {
  box-sizing: border-box;
  padding: 0 32rpx;
}
.cons .details .de_1 {
  box-sizing: border-box;
  padding: 80rpx 0 28rpx;
  text-align: center;
  border-bottom: 2rpx solid #D2D2D7;
}
.cons .details .de_1 .tt1 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.cons .details .de_1 .tt2 {
  font-size: 68rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  margin-top: 20rpx;
}
.cons .details .de_2 {
  box-sizing: border-box;
  padding: 40rpx 0 80rpx;
  text-align: center;
  border-bottom: 2rpx solid #D2D2D7;
}
.cons .details .de_2 .tt1 {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.cons .contitle {
  text-align: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  z-index: 10002 !important;
  background: #fff;
}
.cons .tts {
  text-align: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  height: 100rpx;
}
.shopInfo {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #D2D2D7;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 0 32rpx;
  width: 100%;
  height: 180rpx;
  background: #FBFBFD;
}
.logouts {
  width: 200rpx;
}
.logout {
  height: 68rpx;
  width: 180rpx;
  border-radius: 10rpx;
  background: #eaeaea;
  border: 2rpx solid #707070;
  margin: 0 !important;
  font-size: 24rpx;
}
.shopName {
  font-family: 'Hiragino Sans';
  font-style: normal;
  font-weight: 600;
  font-size: 28rpx;
  color: #1D1D1F;
}
.shopId {
  font-family: 'Hiragino Sans';
  font-style: normal;
  font-weight: 300;
  font-size: 28rpx;
  color: #1D1D1F;
}
.content {
  display: flex;
  flex-wrap: wrap;
  box-sizing: border-box;
  padding: 80rpx 48rpx 0;
  justify-content: space-between;
}
.content .indexItem {
  width: 180rpx;
  height: 180rpx;
  background: #fff;
  box-shadow: 0px 0px 6rpx rgba(0, 0, 0, 0.160784);
  border-radius: 40rpx;
  box-sizing: border-box;
  padding: 26rpx;
  margin-bottom: 80rpx;
  position: relative;
}
.content .indexItem .itemTop {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto;
}
.content .indexItem .itemTop image {
  width: 100%;
  height: 100%;
}
.content .indexItem .itemBot {
  font-family: 'Hiragino Sans';
  font-style: normal;
  font-weight: 500;
  font-size: 20rpx;
  text-align: center;
  color: #707070;
  margin-top: 16rpx;
}
.content .indexItem .bdg {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #D93025;
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  z-index: 99;
  text-align: center;
  line-height: 60rpx;
  color: #fff;
}
.content .indexItem .g {
  background: #1A73E8 !important;
}
.sales {
  display: flex;
  width: 100%;
  height: 200rpx;
  align-items: center;
  box-shadow: 0px 0px 12rpx rgba(0, 0, 0, 0.160784);
  background-color: #fff;
}
.sales .saleItem {
  flex: 1;
  text-align: center;
}
.sales .saleItem .saleTop {
  font-family: 'Hiragino Sans';
  font-style: normal;
  font-weight: 300;
  font-size: 32rpx;
  color: #86868B;
}
.sales .saleItem .saleBot {
  font-family: 'Hiragino Sans';
  font-style: normal;
  font-weight: 400;
  font-size: 48rpx;
  color: #007AFF;
  margin-top: 20rpx;
}
.sales .saleItem .m {
  color: #1D1D1F;
}

