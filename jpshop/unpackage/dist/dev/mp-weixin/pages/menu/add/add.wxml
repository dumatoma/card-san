<view class="contain border_top"><view class="content"><view class="images"><block wx:for="{{array}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="imageItem"><image src="{{item}}" mode></image><view class="close"><image src="../../../static/icons/wclose.png" mode data-event-opts="{{[['tap',[['delImage',[index]]]]]}}" bindtap="__e"></image></view></view></block></view><view class="tips">画像は4枚まで掲載可</view><button class="addImg" type="default" data-event-opts="{{[['tap',[['uploadImage',['$event']]]]]}}" bindtap="__e"><text>+</text><text>画像を選択</text></button><view class="insertContent"><view class="insertItem" style="margin-top:0;"><view class="insertTitle">カテゴリー</view><view data-event-opts="{{[['tap',[['p1',['$event']]]]]}}" class="insertPicker" bindtap="__e"><view>{{cateName}}</view><u-icon vue-id="4ce0eb8a-1" name="arrow-down" bind:__l="__l"></u-icon></view></view><view class="insertItem"><view class="insertTitle"><text style="color:#D93025;">※</text>メニュータイトル</view><u-input bind:input="__e" vue-id="4ce0eb8a-2" placeholder="メニュー名を入力してください" value="{{title}}" data-event-opts="{{[['^input',[['__set_model',['','title','$event',[]]]]]]}}" bind:__l="__l"></u-input></view><view class="insertItem"><view class="insertTitle">メニュー説明</view><u-textarea bind:input="__e" vue-id="4ce0eb8a-3" placeholder="メニュー名を入力してください" value="{{details}}" data-event-opts="{{[['^input',[['__set_model',['','details','$event',[]]]]]]}}" bind:__l="__l"></u-textarea></view><view class="insertItem"><view class="insertTitle">価格(税込)</view><u-input bind:input="__e" vue-id="4ce0eb8a-4" placeholder="価格を入力してください" value="{{price}}" data-event-opts="{{[['^input',[['__set_model',['','price','$event',[]]]]]]}}" bind:__l="__l"></u-input></view><view class="sTitle"><view data-event-opts="{{[['tap',[['changeAppoint',['$event']]]]]}}" class="titleLeft" bindtap="__e"><view class="select" style="{{(appoint==false?'border:2upx solid #d2d2d7':'')}}"><block wx:if="{{appoint}}"><view class="fill"></view></block></view></view><view class="titleRight">予約メニューに設定</view></view><view class="sTitle" style="margin-top:44rpx;"><view class="titleLeft"><view class="select" style="visibility:hidden;"><view class="fill"></view></view></view><view class="titleRight">所要時間(目安)</view></view><view class="sTitle" style="margin-top:44rpx;"><view class="titleLeft"><view class="select" style="visibility:hidden;"><view class="fill"></view></view></view><view class="titleRight" style="font-size:24rpx;color:#707070;"><text style="color:#D93025;">※</text>施術にかかる時間を設定してください。</view></view><view class="sTitle" style="margin-top:44rpx;"><view class="titleLeft"><view class="select" style="visibility:hidden;"><view class="fill"></view></view></view><view class="titleRight"><view data-event-opts="{{[['tap',[['p2',['$event']]]]]}}" class="iPicker" bindtap="__e"><view>{{time+'分'}}</view><u-icon vue-id="4ce0eb8a-5" name="arrow-down" bind:__l="__l"></u-icon></view></view></view></view></view><u-button class="btn" bind:click="__e" vue-id="4ce0eb8a-6" data-event-opts="{{[['^click',[['save']]]]}}" bind:__l="__l" vue-slots="{{['default']}}">保存</u-button><view style="height:110rpx;"></view><u-picker vue-id="4ce0eb8a-7" show="{{show}}" columns="{{columns}}" keyName="name" cancelText=" " confirmText=" " closeOnClickOverlay="{{true}}" title="カテゴリーを選択" data-event-opts="{{[['^confirm',[['e0']]],['^change',[['cateChange']]],['^close',[['close1']]]]}}" bind:confirm="__e" bind:change="__e" bind:close="__e" bind:__l="__l"></u-picker><u-picker vue-id="4ce0eb8a-8" show="{{show1}}" columns="{{columns1}}" keyName="time" cancelText=" " confirmText=" " closeOnClickOverlay="{{true}}" title="時間を選択" data-event-opts="{{[['^change',[['timeChange']]],['^close',[['close2']]],['^confirm',[['e1']]]]}}" bind:change="__e" bind:close="__e" bind:confirm="__e" bind:__l="__l"></u-picker><u-popup vue-id="4ce0eb8a-9" show="{{showPop}}" mode="bottom" round="{{10}}" data-event-opts="{{[['^close',[['closePop']]]]}}" bind:close="__e" bind:__l="__l" vue-slots="{{['default']}}"><view class="pTitle"><view class="pClose"><image src="../../../static/icons/tclose.png" mode></image></view><view class="tDetail">メニュー</view></view><view class="pContent"><view class="pDetail"><view class="dLeft"><view class="dTop">{{''+(title||'メニュータイトル・予約なしの場合')+''}}</view><view class="dBottom"><view class="dPrice">{{'￥'+(price||0)+''}}</view><view class="dTime">{{'所要時間：'+time+'分'}}</view></view></view><view class="dRight"><image class="dr" src="../../../static/icons/collection.png" mode></image></view></view><view class="dc"><view class="dcLeft"><view class="imageCotent"><image class="album" src="../../../static/icons/album.png" mode></image><image style="width:100%;height:100%;" src="{{array[0]}}" mode></image></view></view><view class="dcRight">{{details}}</view></view></view></u-popup></view>