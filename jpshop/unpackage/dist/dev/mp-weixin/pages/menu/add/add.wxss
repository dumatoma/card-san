.dc {
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #d2d2d7;
}
.dc .dcRight {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-left: 20rpx;
}
.dc .imageCotent {
  width: 246rpx;
  height: 246rpx;
  position: relative;
  border-radius: 12rpx;
  border: 2rpx solid #EAEAEA;
}
.dc .imageCotent .album {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 99;
}
.pDetail {
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 44rpx 30rpx 0;
}
.pDetail .dRight {
  width: 60rpx;
  height: 60rpx;
}
.pDetail .dRight .dr {
  width: 100%;
  height: 100%;
}
.pDetail .dTop {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.dBottom {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
}
.dBottom .dPrice {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: rgba(217, 48, 37, 0.65);
  margin-right: 68rpx;
}
.dBottom .dTime {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.pTitle {
  height: 104rpx;
  background: #F5F5F7;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 0 32rpx;
}
.pTitle .tDetail {
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.pTitle .pClose {
  width: 60rpx;
  height: 60rpx;
  margin-right: 202rpx;
}
.pTitle .pClose image {
  width: 100%;
  height: 100%;
}
.sTitle {
  display: flex;
  align-items: center;
  margin: 114rpx 0 0;
}
.btn {
  width: 480rpx;
  height: 96rpx;
  background: #1A73E8;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  line-height: 96rpx;
  text-align: center;
  margin-top: 182rpx;
}
.titleLeft {
  margin-right: 20rpx;
}
.iPicker {
  width: 400rpx;
  height: 80rpx;
  background: rgba(249, 249, 249, 0.94);
  border-radius: 8rpx;
  opacity: 1;
  border: 2rpx solid #D2D2D7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 0 20rpx;
  color: #86868B;
}
.select {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  opacity: 1;
  border: 2rpx solid #1A73E8;
  border-radius: 50%;
  box-sizing: border-box;
  padding: 6rpx;
}
.select .fill {
  background: #1A73E8;
  border-radius: 50%;
  height: 100%;
  width: 100%;
}
.insertContent {
  box-sizing: border-box;
  padding: 120rpx 46rpx 0;
}
.insertContent .insertItem {
  margin-top: 80rpx;
}
.insertContent .insertItem .insertTitle {
  margin-bottom: 10rpx;
}
.insertContent .insertItem .insertPicker {
  height: 80rpx;
  background: #F5F5F7;
  border-radius: 20rpx;
  opacity: 1;
  border: 2rpx solid #D2D2D7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 0 20rpx;
}
.addImg {
  width: 480rpx;
  height: 96rpx;
  background: #F5F5F7;
  border-radius: 20rpx;
  border: 2rpx solid #707070;
  display: flex;
  align-items: center;
  justify-content: center;
}
.addImg text:last-child {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.addImg text:first-child {
  font-size: 50rpx;
  color: #1D1D1F;
  margin-right: 10rpx;
}
.content .tips {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: center;
  margin-top: 50rpx;
  margin-bottom: 26rpx;
}
.content .images {
  display: flex;
  align-items: center;
  overflow-x: scroll;
  box-sizing: border-box;
  padding-left: 32rpx;
  padding-top: 36rpx;
}
.content .images .imageItem {
  position: relative;
  width: 360rpx;
  height: 480rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}
.content .images .imageItem .close {
  position: absolute;
  width: 52rpx;
  height: 52rpx;
  top: 14rpx;
  right: 14rpx;
  z-index: 999;
}
.content .images .imageItem .close image {
  width: 100%;
  height: 100%;
}
.content .images .imageItem image {
  width: 100%;
  height: 100%;
}

