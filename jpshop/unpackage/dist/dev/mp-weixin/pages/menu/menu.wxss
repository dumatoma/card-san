.itemTitle {
  box-sizing: border-box;
  padding: 36rpx 32rpx;
  background: #F5F5F7;
}
.iteContent {
  display: flex;
  align-items: flex-start;
}
.iteContent .iteInfo {
  display: flex;
}
.iteContent .iteInfo .price {
  color: #D93025;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  margin-right: 60rpx;
}
.iteContent .iteInfo .time {
  color: #1D1D1F;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
}
.iteContent .iteImage {
  width: 200rpx;
  height: 200rpx;
  margin-right: 32rpx;
}
.iteContent .iteImage image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}
.iteTitle {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-bottom: 32rpx;
}
.ite {
  box-sizing: border-box;
  padding: 40rpx 32rpx;
}
.tabs {
  display: flex;
  align-items: center;
  overflow-x: scroll;
  box-sizing: border-box;
  padding: 60rpx 32rpx;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
}
.tabs .tab_item {
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  border: 2rpx solid #86868B;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #86868B;
  flex-shrink: 0;
  margin-right: 40rpx;
}

