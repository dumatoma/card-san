<view class="contain"><view class="chatContent"><block wx:for="{{messageArr}}" wx:for-item="item" wx:for-index="index"><view data-event-opts="{{[['tap',[['jumpUrl',['https://www.baidu.com']]]]]}}" class="msgItem" bindtap="__e"><block wx:if="{{item.Showdate}}"><view class="msgDate">{{item.Showdate+'  ('+item.week+')'}}</view></block><view class="userItem" style="{{(item.sender==1?'flex-direction: row-reverse':'')}}"><view><view class="avatar"><image src="{{item.avatar||defaultImage}}" mode></image></view><view class="chatName">{{item.name}}</view></view><view class="detail" style="{{(item.sender==1?'flex-direction: row-reverse':'')}}"><block wx:if="{{item.type==1}}"><view class="msgDetail" style="{{(item.sender==1?'background:#87FA7D':'')}}"><rich-text nodes="{{item.message}}"></rich-text></view></block><block wx:if="{{item.type==2}}"><view class="msgDetailImage"><image src="{{item.message}}" mode="aspectFill" data-event-opts="{{[['tap',[['previewImage',['$0'],[[['messageArr','',index,'message']]]]]]]}}" bindtap="__e"></image></view></block><view class="sendTime">{{item.time}}</view></view></view></view></block><view class="blank"></view></view><view class="sendBox"><view class="boxLeft"><image src="../../../static/icons/fileIcon.png" mode></image><image src="../../../static/icons/photoIcon.png" mode data-event-opts="{{[['tap',[['chooseCamear',['$event']]]]]}}" bindtap="__e"></image><image src="../../../static/icons/imgIcon.png" mode data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" bindtap="__e"></image></view><view class="boxRight"><u-input vue-id="3c3bd7c8-1" placeholder="Aa" shape="circle" value="{{sendMessage}}" data-event-opts="{{[['^confirm',[['send']]],['^input',[['__set_model',['','sendMessage','$event',[]]]]]]}}" bind:confirm="__e" bind:input="__e" bind:__l="__l"></u-input></view></view><block wx:if="{{shows}}"><peiconfirm vue-id="3c3bd7c8-2" dates="{{date}}" number="{{number}}" bind:__l="__l"></peiconfirm></block></view>