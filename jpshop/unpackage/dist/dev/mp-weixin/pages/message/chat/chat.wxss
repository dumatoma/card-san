.contain {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 44px);
}
.contain .msgDetailImage {
  width: 50vw;
}
.contain .msgDetailImage image {
  width: 100%;
}
.contain .chatContent {
  flex: 1;
  background-color: #fff;
  box-sizing: border-box;
  padding: 0 32rpx;
}
.contain .chatContent .userItem {
  display: flex;
}
.contain .chatContent .userItem .avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
}
.contain .chatContent .userItem .avatar image {
  width: 100%;
  height: 100%;
}
.contain .chatContent .userItem .detail {
  display: flex;
  align-items: flex-end;
}
.contain .chatContent .userItem .detail .msgDetail {
  max-width: 492rpx;
  box-sizing: border-box;
  padding: 20rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  background: rgba(143, 168, 248, 0.2);
  border-radius: 20rpx;
  margin: 0 8rpx;
}
.contain .chatContent .userItem .detail .sendTime {
  font-size: 20rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #86868B;
}
.contain .msgItem {
  margin-bottom: 24rpx;
}
.contain .msgItem .msgDate {
  text-align: center;
  padding: 24rpx 0;
}
.contain .blank {
  width: 100vw;
  height: 90rpx;
}
.contain .chatName {
  font-size: 24rpx;
  color: #aaa;
}
.contain .sendBox {
  width: 100vw;
  height: 90rpx;
  background: #F9F9F9;
  box-shadow: 0px -1rpx 0px 2rpx rgba(0, 0, 0, 0.3);
  opacity: 0.93;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 0 32rpx;
  flex-shrink: 0;
  position: fixed;
  bottom: 0;
  left: 0;
}
.contain .sendBox .boxLeft {
  display: flex;
  align-items: center;
}
.contain .sendBox .boxLeft image {
  width: 54rpx;
  height: 42rpx;
  margin-right: 28rpx;
}
.contain .sendBox .boxLeft image:first-child {
  width: 46rpx;
  height: 50rpx;
}
.contain .sendBox .boxRight {
  flex: 1;
}

