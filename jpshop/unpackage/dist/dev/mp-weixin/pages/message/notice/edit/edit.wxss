.uploadImage {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
.mTitle {
  display: flex;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
  padding: 26rpx 32rpx;
  background: #FBFBFD;
  border-top-left-radius: 60rpx;
  border-top-right-radius: 60rpx;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  border-bottom: 2rpx solid #d2d2d7;
}
.mTitle .mClose {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}
.mTitle .mWord {
  flex: 1;
}
.mContent {
  width: 100%;
  height: 1000rpx;
  background: #fff;
}
.mContent .mTip {
  width: 686rpx;
  height: 52rpx;
  background: #707070;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  text-align: center;
  line-height: 52rpx;
  margin: 52rpx auto 60rpx;
}
.mContent .mDetail {
  display: flex;
  align-items: flex-start;
  box-sizing: border-box;
  padding: 0 38rpx;
}
.mContent .mDetail .mAvatar {
  width: 60rpx;
  height: 60rpx;
}
.mContent .mDetail .mChat {
  margin-left: 6rpx;
  background: rgba(143, 168, 248, 0.2);
  box-sizing: border-box;
  padding: 20rpx;
  max-width: 492rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  border-radius: 20rpx;
}
.upload {
  width: 100%;
  height: 646rpx;
  border: 2rpx solid #aaa;
  border-radius: 12rpx;
  text-align: center;
  box-sizing: border-box;
  padding-top: 200rpx;
  position: relative;
}
.upload .upimage {
  width: 126rpx;
  height: 120rpx;
}
.content {
  box-sizing: border-box;
  padding: 60rpx 52rpx;
}
.content .item {
  margin-bottom: 32rpx;
}
.content .itemTitle {
  font-size: 28rpx;
  color: #707070;
  margin-bottom: 10rpx;
}
.content .itemTitle .icon {
  color: #D93025;
}
.content .itemTitle .fu {
  font-size: 24rpx;
  color: #aaa;
}
.btn {
  width: 480rpx;
  height: 96rpx;
  margin-bottom: 80rpx;
}
.tabs {
  height: 120rpx;
  background-color: #FFFFFF;
  display: flex;
  border-top: 2rpx solid #D2D2D7;
  border-bottom: 2rpx solid #D2D2D7;
}
.tabs .active {
  background: rgba(29, 29, 31, 0.1);
  color: #1D1D1F !important;
}
.tabs .tab {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: center;
  color: rgba(29, 29, 31, 0.3);
}
.tabs .tab .tabImage {
  width: 42rpx;
  height: 40rpx;
  margin-right: 16rpx;
}
.tabs .tab .tabImage image {
  width: 100%;
  height: 100%;
}

