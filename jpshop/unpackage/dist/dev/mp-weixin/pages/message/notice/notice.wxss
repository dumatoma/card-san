.u-page {
  padding: 0;
}
.u-demo-block__title {
  padding: 10px 0 2px 15px;
}
.swipe-action__content {
  padding: 25rpx 0;
}
.swipe-action__content__text {
  font-size: 15px;
  color: #303133;
  padding-left: 30rpx;
}
.blank {
  height: 216rpx;
  width: 100%;
}
.btns {
  height: 216rpx;
  background: #F5F5F7;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
  box-sizing: border-box;
  padding: 40rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  z-index: 999;
}
.btns .btn {
  width: 480rpx;
  height: 96rpx;
  background: #34C759;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #FFFFFF;
  line-height: 96rpx;
  margin: 0 auto;
}
.mContent {
  display: flex;
  box-sizing: border-box;
  padding: 20rpx 32rpx;
  align-items: center;
  justify-content: space-between;
}
.mContent .mInfo {
  margin-left: 20rpx;
  margin-right: 12rpx;
}
.mContent .mInfo .mitem {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
  margin-bottom: 20rpx;
}
.mContent .mImage {
  width: 216rpx;
  height: 160rpx;
}
.mContent .mImage image {
  width: 100%;
  height: 100%;
}
.mContent .mRight {
  width: 96rpx;
  height: 48rpx;
  background: #FFFFFF;
  opacity: 1;
  border: 2rpx solid #AAAAAA;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
  text-align: center;
  line-height: 48rpx;
  flex-shrink: 0;
  border-radius: 10rpx;
  margin-left: 12rpx;
}
.itemContent {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 20rpx 32rpx;
}
.itemContent .irange,
.itemContent .idate {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
  margin-top: 20rpx;
}
.itemContent .icontent {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  line-height: 42rpx;
}
.itemContent .iRight {
  width: 96rpx;
  height: 48rpx;
  background: #FFFFFF;
  opacity: 1;
  border: 2rpx solid #1A73E8;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  text-align: center;
  line-height: 48rpx;
  flex-shrink: 0;
  border-radius: 10rpx;
  margin-left: 12rpx;
}
.title {
  height: 126rpx;
  background: #F5F5F7;
  opacity: 1;
  border-top: 2rpx solid #d2d2d7;
  box-sizing: border-box;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.title .titleRight view:first-child {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.title .titleRight view:last-child {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: right;
  margin-top: 10rpx;
}
.title .titleLeft {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: bold;
  color: #1D1D1F;
}

