.title {
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.title .fu {
  color: #AAAAAA !important;
  margin-left: 32rpx;
}
.item {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 28rpx 38rpx;
  border-bottom: 2rpx solid #EAEAEA;
}
.item .itemLeft {
  margin-right: 28rpx;
}
.item .unselect {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  opacity: 1;
  box-sizing: border-box;
  border: 2rpx solid #707070;
  border-radius: 50%;
}
.item .selected {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border: 2rpx solid #1A73E8;
  border-radius: 50%;
  box-sizing: border-box;
  padding: 6rpx;
}
.item .selected .fill {
  width: 100%;
  height: 100%;
  background: #1A73E8;
  border-radius: 50%;
}

