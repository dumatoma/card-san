.contain {
  border-top: 2rpx solid #D2D2D7;
}
.contain .titleContent {
  box-sizing: border-box;
  padding: 60rpx 40rpx 80rpx;
}
.contain .titleContent .title {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.contain .titleContent .choose {
  width: 400rpx;
  height: 80rpx;
  background: rgba(249, 249, 249, 0.94);
  border-radius: 20rpx;
  opacity: 1;
  border: 2rpx solid #AAAAAA;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 0 20rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-top: 20rpx;
}
.contain .titleContent .choose .arrow {
  width: 24rpx;
  height: 24rpx;
}
.contain .titleContent .choose .arrow image {
  width: 100%;
  height: 100%;
}
.contain .item {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 28rpx 38rpx;
  border-bottom: 2rpx solid #EAEAEA;
}
.contain .item .itemLeft {
  margin-right: 28rpx;
}
.contain .item .unselect {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  opacity: 1;
  box-sizing: border-box;
  border: 2rpx solid #707070;
  border-radius: 50%;
}
.contain .item .selected {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border: 2rpx solid #1A73E8;
  border-radius: 50%;
  box-sizing: border-box;
  padding: 6rpx;
}
.contain .item .selected .fill {
  width: 100%;
  height: 100%;
  background: #1A73E8;
  border-radius: 50%;
}

