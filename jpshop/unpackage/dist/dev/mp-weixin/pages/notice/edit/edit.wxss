.titleName {
  font-size: 32rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin: 28rpx 0;
}
.popInfo {
  box-sizing: border-box;
  padding: 56rpx 32rpx;
}
.infoTitle {
  display: flex;
  align-items: center;
}
.infoTitle .itLeft {
  width: 62rpx;
  height: 62rpx;
  margin-right: 32rpx;
}
.infoTitle .itLeft image {
  width: 100%;
  height: 100%;
}
.infoTitle .itRight .rightTop {
  font-size: 28rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.infoTitle .itRight .rightBottom text:first-child {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #6E6E73;
  margin-right: 40rpx;
}
.infoTitle .itRight .rightBottom text:last-child {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
}
.popTitle {
  text-align: center;
  position: relative;
  height: 112rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
}
.popTitle view {
  flex: 1;
  position: relative;
  left: -32rpx;
}
.popTitle .closee {
  width: 60rpx;
  height: 60rpx;
  margin-left: 32rpx;
}
.tip {
  box-sizing: border-box;
  padding: 10rpx 40rpx 32rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
}
.btn {
  width: 480rpx;
  height: 96rpx;
  margin-top: 100rpx;
}
.select {
  box-sizing: border-box;
  padding: 0 40rpx;
}
.select .selectItem {
  width: 400rpx;
  height: 80rpx;
  background: rgba(249, 249, 249, 0.94);
  border-radius: 20rpx;
  border: 2rpx solid #AAAAAA;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 0 20rpx;
}
.dateitem {
  box-sizing: border-box;
  padding: 0 40rpx;
}
.can {
  width: 100%;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #aaa;
  overflow: hidden;
  margin: 10rpx 0 60rpx;
}
.can .canLeft {
  background: #EAEAEA;
  text-align: center;
  border-right: 2rpx solid #aaa;
  height: 100%;
  line-height: 80rpx;
  width: 80rpx;
  box-sizing: border-box;
  padding-left: 8rpx;
}
.inp {
  box-sizing: border-box;
  padding: 0 54rpx;
  margin-bottom: 80rpx;
}
.inp .inpTitle {
  margin-bottom: 10rpx;
}
.swit {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 44rpx 36rpx;
}
.addImage {
  width: 480rpx;
  height: 96rpx;
  background: #F5F5F7;
  border: 2rpx solid #707070;
  text-align: center;
  line-height: 96rpx;
  margin: 80rpx auto 98rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.addImage text {
  font-size: 60rpx;
  margin-right: 26rpx;
  position: relative;
  top: -5rpx;
}
.topImage {
  box-sizing: border-box;
  padding-top: 40rpx;
  display: flex;
  overflow-x: scroll;
  padding-left: 118rpx;
}
.topImage .bannerItem {
  width: 514rpx;
  height: 344rpx;
  flex-shrink: 0;
  margin-right: 46rpx;
  position: relative;
}
.topImage .bannerItem .close {
  width: 52rpx;
  height: 52rpx;
  position: absolute;
  right: 14rpx;
  top: 14rpx;
  z-index: 999;
}
.topImage .bannerItem .close image {
  width: 100%;
  height: 100%;
}
.topImage .bannerItem image {
  width: 100%;
  height: 100%;
}

