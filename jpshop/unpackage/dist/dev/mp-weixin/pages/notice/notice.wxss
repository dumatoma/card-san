.border {
  border-radius: 8rpx;
  opacity: 1;
  border: 2rpx solid #707070;
}
.item {
  display: flex;
  margin-bottom: 40rpx;
}
.item .itemLeft {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}
.item .itemLeft image {
  width: 100%;
  height: 100%;
}
.item .itemRight {
  margin-left: 50rpx;
  width: 588rpx;
  box-shadow: 0px 0px 20rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 20rpx;
  overflow: hidden;
}
.item .itemRight .iImage {
  width: 100%;
  height: 394rpx;
}
.item .itemRight .iImage image {
  width: 100%;
  height: 100%;
}
.content {
  box-sizing: border-box;
  padding: 40rpx;
}
.content .iInfo {
  box-sizing: border-box;
  padding: 20rpx;
}
.content .iInfo .info2 {
  font-size: 28rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.content .iInfo .info3 {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-top: 20rpx;
}
.content .iInfo .info3 text {
  color: #1A73E8;
}
.content .iInfo .info4 {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-top: 20rpx;
}
.content .iInfo .info1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}
.content .iInfo .info1 .i1Left {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.content .iInfo .info1 .i1Right {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  background: #FFFFFF;
  border: 2rpx solid #1A73E8;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
}
.content .iInfo .info5 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-top: 20rpx;
}
.content .iInfo .info5 .infoItem {
  flex: 1;
}
.title {
  height: 126rpx;
  background: #fff;
  box-shadow: 0px 0px 10rpx 2rpx rgba(0, 0, 0, 0.16);
  box-sizing: border-box;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.title .titleRight view:first-child {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.title .titleRight view:last-child {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: right;
  margin-top: 10rpx;
}
.title .titleLeft {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: bold;
  color: #1D1D1F;
}

