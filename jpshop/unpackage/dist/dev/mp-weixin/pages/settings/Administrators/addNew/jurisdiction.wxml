<view><block wx:if="{{query.type=='add'}}"><view class="info"><view class="in1">副管理者に付与する権限を選択して下さい。</view><view class="in2">通常利用には「運営」「各種設定」の選択をおすすめします。</view><view class="in3">店舗名：TOP&HAIR RESORT(店舗名)</view><view class="in3">{{'副管理者名：'+query.name}}</view><view class="in3">{{'電話番号：'+query.phone}}</view></view></block><block wx:else><view class="info"><view class="in1">店舗名：TOP&HAIR RESORT(店舗名)</view><view class="in4"><view class="iname">副管理者名</view><u-input bind:input="__e" vue-id="16f7168a-1" value="{{name}}" data-event-opts="{{[['^input',[['__set_model',['','name','$event',[]]]]]]}}" bind:__l="__l"></u-input></view><view class="in4"><view class="iname">電話番号(SMS認証)</view><u-input bind:input="__e" vue-id="16f7168a-2" value="{{phone}}" data-event-opts="{{[['^input',[['__set_model',['','phone','$event',[]]]]]]}}" bind:__l="__l"></u-input></view></view></block><view class="content"><block wx:for="{{array}}" wx:for-item="item" wx:for-index="index"><view class="juItem"><view class="title"><view data-event-opts="{{[['tap',[['selectAll',[index]]]]]}}" class="selectContents" bindtap="__e"><block wx:if="{{!item.checked}}"><view class="unselect"></view></block><block wx:if="{{item.checked}}"><view class="selected"><view class="fill"></view></view></block></view><view>{{item.name}}</view></view><view class="inner"><block wx:for="{{item.jus}}" wx:for-item="ite" wx:for-index="idx"><view class="inItem"><view data-event-opts="{{[['tap',[['selectone',[index,idx]]]]]}}" class="select" bindtap="__e"><block wx:if="{{ite.checked}}"><image src="../../../../static/icons/select.png" mode></image></block></view><view class="inName">{{ite.name}}</view></view></block></view></view></block></view><u-button class="nextStep" vue-id="16f7168a-3" text="保存" data-event-opts="{{[['^click',[['save']]]]}}" bind:click="__e" bind:__l="__l"></u-button><view style="height:200rpx;"></view></view>