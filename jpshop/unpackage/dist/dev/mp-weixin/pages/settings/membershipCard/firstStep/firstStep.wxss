.tips {
  box-sizing: border-box;
  padding: 0 46rpx 42rpx 48rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  box-shadow: 0px 4rpx 6rpx 2rpx rgba(0, 0, 0, 0.16);
}
.fImage {
  width: 100%;
  height: 100%;
}
.preContent {
  box-sizing: border-box;
  padding: 80rpx 66rpx;
  height: 60vh;
}
.preContent .preItem {
  width: 292rpx;
}
.preContent .preItem .preImage {
  width: 280rpx;
  height: 170rpx;
  background: #FBFBFD;
  box-shadow: 0px 0px 6rpx 2rpx rgba(0, 0, 0, 0.16);
  overflow: hidden;
}
.preContent .preItem .preName {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: center;
}
.preTitle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2rpx solid #d2d2d7;
  border-top: 2rpx solid #d2d2d7;
  box-sizing: border-box;
  padding: 32rpx;
}
.preTitle .iconLeft {
  width: 66rpx;
  height: 48rpx;
}
.preTitle .iconLeft image {
  width: 100%;
  height: 100%;
}
.preTitle .iconMiddle {
  font-size: 48rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.preTitle .iconRight {
  width: 66rpx;
  height: 60rpx;
}
.preTitle .iconRight image {
  width: 100%;
  height: 100%;
}
.pTitle {
  position: relative;
  height: 111rpx;
  background: #FBFBFD;
  border-radius: 32rpx;
}
.pTitle .pt {
  width: 100%;
  text-align: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  line-height: 111rpx;
}
.pTitle .closeImage {
  width: 60rpx;
  height: 60rpx;
  position: absolute;
  top: 26rpx;
  left: 32rpx;
}
.pTitle .closeImage image {
  width: 100%;
  height: 100%;
}
.btn {
  width: 480rpx;
  height: 100rpx;
  background: rgba(26, 115, 232, 0.6);
  border-radius: 20rpx;
  margin-top: 120rpx;
}
.item {
  box-sizing: border-box;
  padding: 0 46rpx;
  margin-bottom: 80rpx;
}
.item .itemName {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
  margin-bottom: 20rpx;
}
.item .itemName text {
  color: #D93025 !important;
}
.item .uploadImage {
  width: 100%;
  height: 396rpx;
  background: #E4E4E4;
  box-shadow: 0px 0px 10rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}
.item .uploadImage .add {
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
          transform: translate(-50%, -50%);
}
.titleContent {
  box-sizing: border-box;
  padding-top: 40rpx;
  margin-bottom: 80rpx;
}
.titleContent .title {
  height: 112rpx;
  background: #F5F5F7;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
  line-height: 112rpx;
  box-sizing: border-box;
  padding-left: 40rpx;
}

