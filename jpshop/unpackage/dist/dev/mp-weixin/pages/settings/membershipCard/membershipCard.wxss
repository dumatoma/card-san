.introduce {
  box-sizing: border-box;
  padding: 0 38rpx;
  margin-top: 80rpx;
}
.introduce .introContent {
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.introduce .introContent view {
  padding: 10rpx 0;
}
.pContent {
  width: 100%;
  height: 80vh;
  background: #fff;
  overflow-y: scroll;
}
.pContent .pItem {
  box-sizing: border-box;
  padding: 0 20rpx;
  margin-bottom: 80rpx;
}
.pContent .pItem .pitemImage {
  width: 100%;
}
.pContent .itemTitle {
  display: flex;
  align-items: center;
}
.pContent .itemTitle .typeName {
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
  margin-left: 20rpx;
}
.pContent #title {
  box-sizing: border-box;
  padding: 80rpx 0 126rpx;
  text-align: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.pTitle {
  height: 112rpx;
  background: #FBFBFD;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2rpx solid #d2d2d7;
  box-sizing: border-box;
  padding: 0 32rpx;
}
.pTitle .pTitlename {
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.pTitle .pSave {
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
}
.pTitle .pClose {
  width: 60rpx;
  height: 60rpx;
}
.pTitle .pClose image {
  width: 100%;
  height: 100%;
}
.itemTitle {
  font-size: 32rpx;
  font-family: Hiragino Sans-W6, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.itemLeft {
  margin-right: 30rpx;
}
.items,
.bk {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-top: 20rpx;
}
.itemImage {
  width: 550rpx;
  height: 328rpx;
  background: #FFFFFF;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
  margin-top: 40rpx;
}
.itemImage image {
  width: 100%;
  height: 100%;
}
.listItem {
  display: flex;
  box-sizing: border-box;
  padding: 40rpx;
}
.bk {
  display: flex;
  align-items: center;
}
.colorSqu {
  width: 200rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
}
.u-page {
  padding: 0;
}
.u-demo-block__title {
  padding: 10px 0 2px 15px;
}
.swipe-action__content {
  padding: 25rpx 0;
}
.swipe-action__content__text {
  font-size: 15px;
  color: #303133;
  padding-left: 30rpx;
}
.addNew {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
  margin-top: 60rpx;
  box-sizing: border-box;
  padding: 40rpx 0;
  box-shadow: 0px 8rpx 10rpx 1rpx rgba(0, 0, 0, 0.16);
}
.addNew text {
  margin-left: 10rpx;
}
.top1 {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 60rpx 40rpx 0;
}
.top1 .topLeft {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  margin-right: 36rpx;
}
.topRight {
  flex: 1;
}
.noData {
  width: 100%;
  margin-top: 192rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  text-align: center;
}
.pickers {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 80rpx;
  background: rgba(249, 249, 249, 0.94);
  border-radius: 20rpx;
  opacity: 1;
  border: 2rpx solid #AAAAAA;
  box-sizing: border-box;
  padding: 0 20rpx;
}
.pickers .pickerName {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}

