.selece {
  display: flex;
  align-items: center;
}
.selece .seName {
  font-size: 32rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
  margin-left: 20rpx;
}
.butt {
  width: 480rpx;
  height: 96rpx;
  background: #1A73E8;
  border-radius: 20rpx;
  margin-top: 600rpx;
}
.cont {
  width: 100vw;
  height: 100vh;
  box-sizing: border-box;
  padding: 46rpx;
  border-top: 2rpx solid #d2d2d7;
}
.cont .tips {
  display: flex;
  background: #F5F5F7;
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 20rpx;
}
.cont .tips .tipIcon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.cont .tips .tipIcon image {
  width: 100%;
  height: 100%;
}
.cont .insertContent {
  box-sizing: border-box;
  padding: 78rpx 0 86rpx;
}
.cont .insertContent .insertName {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #86868B;
  margin-bottom: 10rpx;
}

