#addBtn {
  width: 200rpx;
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 !important;
}
.pTitle {
  position: relative;
  height: 111rpx;
  background: #FBFBFD;
  border-radius: 32rpx;
}
.pTitle .pt {
  width: 100%;
  text-align: center;
  font-size: 40rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  line-height: 111rpx;
}
.pTitle .closeImage {
  width: 60rpx;
  height: 60rpx;
  position: absolute;
  top: 26rpx;
  left: 32rpx;
}
.pTitle .closeImage image {
  width: 100%;
  height: 100%;
}
.pContent {
  width: 100%;
  height: 80vh;
  overflow-y: scroll;
}
.blank {
  height: 120rpx;
}
.switchItem {
  display: flex;
  box-sizing: border-box;
  padding: 44rpx 36rpx;
  justify-content: space-between;
  border-bottom: 2rpx solid #d2d2d7;
}
#save {
  width: 480rpx;
  margin-top: 120rpx;
}
.basicInfo {
  box-sizing: border-box;
  padding: 60rpx 46rpx;
}
.addressContent {
  box-sizing: border-box;
  padding: 0 46rpx;
}
.addItemLeft {
  width: 400rpx;
  height: 88rpx;
}
.addressItem {
  box-sizing: border-box;
  margin-bottom: 60rpx;
}
.addressItem .addressItemTitle {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #86868B;
  margin-bottom: 10rpx;
}
.addressItem .addressItemContent {
  display: flex;
  justify-content: space-between;
}
.addressItem .addressItemContent .addressItemContent .addItemLeft {
  width: 400rpx;
  height: 88rpx;
}
.tip {
  box-sizing: border-box;
  padding: 10rpx 0 80rpx 46rpx;
  font-size: 24rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #AAAAAA;
}
.calendarShows {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 44rpx 36rpx;
}
.infoItem {
  margin-bottom: 60rpx;
}
.infoTitle {
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #707070;
}
.pickers {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 80rpx;
  background: rgba(249, 249, 249, 0.94);
  border-radius: 20rpx;
  opacity: 1;
  border: 2rpx solid #AAAAAA;
  box-sizing: border-box;
  padding: 0 20rpx;
}
.title {
  background: #f5f5f7;
  box-sizing: border-box;
  padding: 44rpx 46rpx;
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: rgba(29, 29, 31, 0.9);
}
.xz {
  margin: 80rpx 0 40rpx;
  text-align: center;
  font-size: 22rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
}
.addImage {
  width: 480rpx;
  height: 96rpx;
  background: #F5F5F7;
  border: 2rpx solid #707070;
  text-align: center;
  line-height: 96rpx;
  margin: 0 auto 98rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.addImage text {
  font-size: 60rpx;
  margin-right: 26rpx;
  position: relative;
  top: -5rpx;
}
.topImage {
  box-sizing: border-box;
  padding-top: 40rpx;
  display: flex;
  overflow-x: scroll;
  padding-left: 28rpx;
}
.topImage .bannerItem {
  width: 514rpx;
  height: 344rpx;
  flex-shrink: 0;
  margin-right: 46rpx;
  position: relative;
}
.topImage .bannerItem .close {
  width: 52rpx;
  height: 52rpx;
  position: absolute;
  right: 14rpx;
  top: 14rpx;
  z-index: 99;
}
.topImage .bannerItem .close image {
  width: 100%;
  height: 100%;
}
.topImage .bannerItem image {
  width: 100%;
  height: 100%;
}

