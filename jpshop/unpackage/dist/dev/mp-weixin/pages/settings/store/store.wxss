.resultContent {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 0 32rpx;
}
.resultContent .result {
  width: 164rpx;
  height: 164rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-right: 46rpx;
}
.resultContent .colorList {
  display: flex;
  flex-wrap: wrap;
  padding-bottom: 40rpx;
}
.resultContent .colorList .colorItem {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 44rpx;
  box-sizing: border-box;
  padding: 8rpx;
}
.resultContent .colorList .colorItem .colorSelected {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}
.resultContent .colorList .colorItem:nth-child(1) {
  margin-bottom: 44rpx;
}
.resultContent .colorList .colorItem:nth-child(5n) {
  margin-right: 0;
}

