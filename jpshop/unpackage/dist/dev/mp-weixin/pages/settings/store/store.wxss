.menuContent {
  width: 140rpx;
  height: 140rpx;
  background: #FFFFFF;
  box-shadow: 0px 0px 20rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 20rpx;
}
.maskContent {
  background: #fff;
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100vw;
}
.ptitle {
  display: flex;
  padding: 20rpx 30rpx;
  position: relative;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
}
.pName {
  position: absolute;
  left: 50%;
  -webkit-transform: translateX(-50%);
          transform: translateX(-50%);
  top: 20rpx;
}
.mask {
  position: fixed;
  top: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.8);
  width: 100vw;
  height: 100vh;
}
.menus {
  display: flex;
}
.menus .menusItem {
  flex: 1;
  text-align: center;
}
.menuImage image {
  width: 120rpx;
  height: 60rpx;
}
.menuName {
  font-size: 20rpx;
  text-align: center;
}
.tab {
  width: 100%;
  height: 210rpx;
  background: #fff;
  box-sizing: border-box;
  padding: 64rpx 30rpx 0;
  border-top: 2rpx solid #D2D2D7;
}
.menuIcon {
  text-align: center;
  box-sizing: border-box;
  padding: 28rpx 0 0 0;
}
.menuIcon image {
  height: 62rpx;
  width: 120rpx;
}
.tips {
  font-size: 28rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1D1D1F;
  line-height: 42rpx;
}
.menuStatus {
  text-align: center;
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
}
.gray {
  background: #F5F5F7;
  box-sizing: border-box;
  padding: 60rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.menuItem {
  flex-shrink: 0;
  margin-bottom: 80rpx;
}
.menuItem:nth-child(2) {
  margin: 0 100rpx;
}
.btns {
  display: flex;
  align-items: center;
  width: 100%;
  height: 190rpx;
}
.btns .butn {
  flex: 1;
  text-align: center;
}
.btns .colorRed {
  font-size: 40rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: rgba(217, 48, 37, 0.65);
}
.btns .colorBlue {
  font-size: 40rpx;
  font-family: Hiragino Sans-W3, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
}
.colorSqu {
  width: 96rpx;
  height: 96rpx;
  box-shadow: 0px 0px 12rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 50%;
}
.tabItem {
  text-align: center;
  line-height: 64rpx;
  flex: 1;
}
.tabItems {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 40rpx;
  border-top: 2rpx solid #d2d2d7;
}
.tabItems:last-child {
  border-bottom: 2rpx solid #d2d2d7;
}
.tabContent {
  display: flex;
  align-items: center;
  background: #EAEAEA;
  width: 100%;
  border-radius: 16rpx;
  height: 72rpx;
}
.active {
  width: 344rpx;
  height: 64rpx;
  background: #FFFFFF;
  box-shadow: 0px 6rpx 16rpx 2rpx rgba(0, 0, 0, 0.16);
  border-radius: 16rpx;
  opacity: 1;
  border: 2rpx solid rgba(255, 255, 255, 0.04);
  font-size: 32rpx;
  font-family: Hiragino Sans-W5, Hiragino Sans;
  font-weight: normal;
  color: #1A73E8;
}

